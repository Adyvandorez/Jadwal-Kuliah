<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_notification_pill"
    android:padding="8dp">

    <LinearLayout
        android:id="@+id/text_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:orientation="horizontal"
        android:layout_alignParentStart="true"
        android:layout_marginStart="16dp"
        android:layout_toStartOf="@+id/button_container">

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:00"
            android:textColor="@color/beige_soft"
            android:textSize="36sp"
            android:fontFamily="sans-serif-medium" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center_vertical"
                android:src="@android:drawable/ic_lock_idle_alarm"
                android:tint="@color/gold_primary" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Alarm berbunyi"
                android:textColor="@color/gold_primary"
                android:textSize="16sp"
                android:ellipsize="end"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_snooze"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_circle_dark"
            android:src="@android:drawable/ic_popup_sync"
            android:tint="@color/gold_primary"
            android:padding="14dp"
            android:scaleType="centerInside"
            android:layout_marginEnd="10dp" />

        <ImageButton
            android:id="@+id/btn_stop"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_circle_gold"
            android:src="@android:drawable/ic_media_pause"
            android:tint="@color/brown_dark"
            android:padding="14dp"
            android:scaleType="centerInside" />
    </LinearLayout>

</RelativeLayout>
